# ─── API URL ──────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT (npm run dev):
#   VITE_API_URL=http://localhost:5001/api
#
# PRODUCTION (Docker build for server/domain):
#   VITE_API_URL=/api
#
# Use /api for production. The browser will automatically use the domain
# (e.g., http://dualityacm.bmu.edu.in/api) without hardcoding any IP or port.
VITE_API_URL=/api

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Must match GOOGLE_CLIENT_ID in the backend .env exactly.
# Add your domain (http://dualityacm.bmu.edu.in) to "Authorized JavaScript Origins"
# in Google Cloud Console → APIs & Services → Credentials.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
