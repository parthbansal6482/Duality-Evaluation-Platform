{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/socket.io/:path*",
      "destination": "http://51.21.134.56/socket.io/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "http://51.21.134.56/api/:path*"
    }
  ]
}