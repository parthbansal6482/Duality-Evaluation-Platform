# Environment Variables
NODE_ENV=development
PORT=5001

# MongoDB — Extended (contest platform)
# For local: mongodb://localhost:27017/dsa-contest
# For Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/dsa-extended
MONGODB_URI=

# MongoDB — Practice (individual practice platform, SEPARATE database)
# For local: mongodb://localhost:27017/dsa-practice
# For Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/dsa-practice
MONGODB_PRACTICE_URI=

# JWT Secret
JWT_SECRET=provide-a-long-random-string-here
JWT_EXPIRE=7d

# CORS & Client URL
# The URL where your frontend is running
CLIENT_URL=http://localhost:5173
# Comma separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Google Client ID (Must match the one in frontend .env)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
