# Environment Variables
NODE_ENV=development
PORT=5001

# MongoDB Configuration
# Keep these two URIs separated to isolate data across product modes:
# 1) Competition / Duality Extended (team battles)
# 2) Quiz + Assignments (Google-auth duality modes)
#
# Recommended:
# MONGODB_COMPETITION_URI=mongodb://localhost:27017/duality-competition
# MONGODB_DUALITY_URI=mongodb://localhost:27017/duality-academics
MONGODB_COMPETITION_URI=
MONGODB_DUALITY_URI=

# Backward-compatible legacy keys (optional fallback)
MONGODB_URI=
MONGODB_EXTENDED_URI=

# Safety guard: keep false unless you intentionally want shared DB
ALLOW_SHARED_MONGODB=false
# Hard guard: if true, server fails when collections are mixed across DBs
STRICT_DB_BOUNDARIES=true
REDIS_URL=redis://localhost:6379

# JWT Secret
JWT_SECRET=provide-a-long-random-string-here
JWT_EXPIRE=7d

# CORS & Client URL
# The URL where your frontend is running
CLIENT_URL=http://localhost:5173
# Comma separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Google Client ID (Must match the one in frontend .env)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
